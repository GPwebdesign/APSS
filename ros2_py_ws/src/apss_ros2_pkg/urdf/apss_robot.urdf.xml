<?xml version="1.0"?>
<robot name="apss_robot">

  <!-- base_footprint: proiezione del robot sul pavimento -->
  <link name="base_footprint"/>

  <!-- base_link: centro geometrico del robot a livello pavimento -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.32 0.29 0.33"/>
      </geometry>
      <origin xyz="0 0 0.165" rpy="0 0 0"/>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.32 0.29 0.33"/>
      </geometry>
      <origin xyz="0 0 0.165" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- base_footprint → base_link -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Frame LiDAR RPLIDAR A1M8 -->
  <!-- z=0.33m, centro superiore, offset fisico 90° compensato con rpy Z=1.5708 -->
  <link name="laser">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.17"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- base_link → laser -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.0 0.0 0.33" rpy="0 0 1.5708"/>
  </joint>

  <!-- Frame camera OV5647 -->
  <!-- x=0.16m davanti, z=0.20m altezza -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- base_link → camera_link -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.16 0.0 0.20" rpy="0 0 0"/>
  </joint>

</robot>
